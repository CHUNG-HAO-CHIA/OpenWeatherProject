<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Safe zone: 18–90 × 18–90
        Sun  : center (72, 36), disc r=13  — top y=23, bottom y=49
        Cloud: 4 bumps, peaks y≈49–65, base y=82
               cloud just kisses the lower edge of the sun disc
    -->

    <!-- Sun outer atmospheric halo -->
    <path android:pathData="M42,36 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="72" android:centerY="36"
                android:gradientRadius="30"
                android:startColor="#40FFD54F"
                android:endColor="#00FFD54F"/>
        </aapt:attr>
    </path>

    <!-- Sun inner glow -->
    <path android:pathData="M54,36 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="72" android:centerY="36"
                android:gradientRadius="18"
                android:startColor="#70FFD54F"
                android:endColor="#00FFD54F"/>
        </aapt:attr>
    </path>

    <!-- Sun disc -->
    <path
        android:fillColor="#FFD54F"
        android:pathData="M59,36 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0"/>

    <!-- Sun highlight (upper-left of disc) -->
    <path
        android:fillColor="#70FFFFFF"
        android:pathData="M65,31 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0"/>

    <!-- Cloud drop shadow -->
    <path
        android:fillColor="#28103050"
        android:pathData="M24,85 L84,85 C88,85 91,82 90,78 C90,74 87,72 83,73 C84,68 81,65 77,66 C77,62 73,60 69,62 C69,58 65,56 61,58 C61,54 56,52 52,55 C52,60 47,60 44,63 C42,63 38,64 36,67 C34,68 30,70 28,74 C24,74 21,78 21,81 C21,84 24,85 24,85 Z"/>

    <!-- Cloud main body: white → ice-blue gradient -->
    <path android:pathData="M22,82 L82,82 C86,82 89,79 88,75 C88,71 85,69 81,70 C82,65 79,62 75,63 C75,59 71,57 67,59 C67,55 63,53 59,55 C59,51 54,49 50,52 C50,57 45,57 42,60 C40,60 36,61 34,64 C32,65 28,67 26,71 C22,71 19,75 19,78 C19,81 22,82 22,82 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="49"
                android:endX="54" android:endY="82"
                android:startColor="#FFFFFF"
                android:endColor="#BDD8F0"/>
        </aapt:attr>
    </path>

    <!-- Cloud top-surface highlight -->
    <path
        android:fillColor="#45FFFFFF"
        android:pathData="M50,52 C50,57 45,57 42,60 C40,59 36,58 34,55 C36,53 40,51 43,51 C43,48 47,46 50,48 C50,50 50,52 50,52 Z"/>

</vector>
